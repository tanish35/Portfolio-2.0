# Canonical public URL of the site (no trailing slash).
# Used for metadata, canonical tags, sitemap, robots and Open Graph images.
# Falls back to https://tanish.site if unset.
NEXT_PUBLIC_SITE_URL=https://tanish.site

# Microsoft Clarity project id (from clarity.microsoft.com). Enables analytics.
NEXT_PUBLIC_CLARITY_PROJECT_ID=xhstzdyysl
